#include <stdio.h>
#include <stdlib.h>

struct Node {
    int data;
    struct Node* left;
    struct Node* right;
};

// Create new node
struct Node* createNode(int data) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = data;
    newNode->left = newNode->right = NULL;
    return newNode;
}

// Insert in BST
struct Node* insert(struct Node* root, int data) {
    if (root == NULL)
        return createNode(data);

    if (data < root->data)
        root->left = insert(root->left, data);
    else
        root->right = insert(root->right, data);

    return root;
}

// Print nodes in given range
void printInRange(struct Node* root, int low, int high) {
    if (root == NULL)
        return;

    // Left subtree
    if (root->data > low)
        printInRange(root->left, low, high);

    // Current node
    if (root->data >= low && root->data <= high)
        printf("%d ", root->data);

    // Right subtree
    if (root->data < high)
        printInRange(root->right, low, high);
}

// Driver code
int main() {
    struct Node* root = NULL;

    // Example tree
    root = insert(root, 17);
    insert(root, 4);
    insert(root, 18);
    insert(root, 2);
    insert(root, 9);

    int low = 4, high = 24;

    printf("Nodes in range: ");
    printInRange(root, low, high);

    return 0;
}
