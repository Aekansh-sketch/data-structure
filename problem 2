#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX 100000

char stack[MAX];
int top = -1;

// Push
void push(char ch) {
    stack[++top] = ch;
}

// Pop
char pop() {
    if (top == -1)
        return '\0';
    return stack[top--];
}

// Check matching
int isMatching(char open, char close) {
    return (open == '(' && close == ')') ||
           (open == '{' && close == '}') ||
           (open == '[' && close == ']');
}

// Check balanced
int isBalanced(char *s) {
    for (int i = 0; s[i] != '\0'; i++) {
        char ch = s[i];

        // Opening brackets
        if (ch == '(' || ch == '{' || ch == '[') {
            push(ch);
        }
        // Closing brackets
        else if (ch == ')' || ch == '}' || ch == ']') {
            if (top == -1)
                return 0;

            char popped = pop();
            if (!isMatching(popped, ch))
                return 0;
        }
    }

    return (top == -1); // stack must be empty
}

int main() {
    char s[MAX];

    printf("Enter expression: ");
    scanf("%s", s);

    if (isBalanced(s))
        printf("true\n");
    else
        printf("false\n");

    return 0;
}
